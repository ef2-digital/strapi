{
    "collectionName": "components_shared_seos",
    "info": {
        "displayName": "seo"
    },
    "options": {},
    "attributes": {
        "metaTitle": {
            "type": "string",
            "maxLength": 60
        },
        "metaDescription": {
            "type": "string",
            "maxLength": 160,
            "minLength": 50
        },
        "metaImage": {
            "type": "media",
            "multiple": false,
            "required": true,
            "allowedTypes": ["images", "files", "videos"]
        },
        "metaSocial": {
            "type": "component",
            "repeatable": true,
            "component": "shared.meta-social"
        },
        "keywords": {
            "type": "text",
            "regex": "[^,]+"
        },
        "metaRobots": {
            "type": "string",
            "regex": "[^,]+"
        },
        "structuredData": {
            "type": "json"
        },
        "metaViewport": {
            "type": "string"
        },
        "canonicalURL": {
            "type": "string"
        }
    }
}
